# 司法院資料開放平臺申請的帳號密碼。
# 從網頁貼進來時容易夾帶空白，腳本會去除前後空白後再送出。
JUDICIAL_API_USER=
JUDICIAL_API_PASSWORD=

# 已發布網站的網址。累積式索引靠它取回前一版再合併，本機開發可留空。
SITE_URL=

# 裁判紀錄的起點，指向以官方月包在本機匯入後上傳的 judgments.json。
# 留空時每晚同步只會從 SITE_URL 上的前一版累加。
JUDICIAL_SOURCE_URL=

# 全國性平調查專業人才名冊的來源網址。名冊含兩千餘筆真實姓名，
# 不進版控，由建置時取得。留空時網站顯示名冊無法載入，其餘功能正常。
TALENT_SOURCE_URL=

# 每個新聞監測詞往回翻幾頁，每頁 20 則。留空使用預設 2。
# 重建歷史索引時調大跑一次即可。
NEWS_PAGES=
