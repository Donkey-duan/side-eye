# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# typescript
next-env.d.ts
tsconfig.tsbuildinfo

# 建置時產生的資料檔，不進版控。
# 名冊含 2000 多筆真實姓名，git 歷史永久保存，因此改由 Actions 於建置時取得。
/public/data/talent.json
/public/data/news.json
/public/data/judicial.json
/public/data/judicial-judges.json
/public/data/judgments.json

# 裁判書抽取的本機快取，以及解壓期間的暫存
/cache/
/.judgments-work/

# 產生的下載索引
/下載索引.html
